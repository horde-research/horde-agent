# ── LLM Client (core.llm) ─────────────────────────────────────────────
# Used by GenerateTaxonomyTool, BuildSftDatasetTool, and other LLM calls.
# LLM_API_KEY falls back to OPENAI_API_KEY if not set.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-llm-api-key-here

# ── OpenAI / Agentic Layer (core.agentic) ────────────────────────────
# Used by the agentic decision pipeline (minimal_agentic mode).
# Also used as fallback for LLM_API_KEY above.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=
OPENAI_TIMEOUT_S=60
OPENAI_MAX_RETRIES=2

# ── Data Collection (kazparserbot) ───────────────────────────────────
SERPER_API_KEY=your-serper-api-key-here
