# ── LLM Client (core.llm) ─────────────────────────────────────────────
# Used by all LLM calls: taxonomy generation, SFT annotation, agentic decisions.
# Only these three variables are needed for the entire project.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-llm-api-key-here

# ── Data Collection (kazparserbot) ───────────────────────────────────
SERPER_API_KEY=your-serper-api-key-here
