# ══════════════════════════════════════════════════════════════════════
# Horde Agent — Pipeline Configuration
# ══════════════════════════════════════════════════════════════════════
# Copy to .env and fill in. Run with: python -m agent.main

# ── Pipeline ──────────────────────────────────────────────────────────
# Country/culture for taxonomy generation.
COUNTRY=Kazakhstan

# Directory where all outputs are saved (taxonomy, data, SFT, adapters, reports).
RUN_DIR=output/run

# Resume from an existing SFT JSONL (train → eval → report only; skips taxonomy, collect, annotate):
#   python -m agent.main --mode workflow --data_path /abs/path/to/run/sft/sft.jsonl --out_dir /abs/path/to/run
# Use the same --out_dir as the original run so artifacts stay together.

# ── LLM Client ────────────────────────────────────────────────────────
# Used by ALL LLM calls: taxonomy, SFT annotation, agentic decisions.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-llm-api-key-here
# LLM_TEMPERATURE=0.7

# ── Data Collection (Serper) ──────────────────────────────────────────
SERPER_API_KEY=your-serper-api-key-here
# How many Google results per query (before filtering). Default: 10
# SERPER_RESULTS_PER_QUERY=10
# How many top pages to scrape per query. Default: 5
# SERPER_TOP_RESULTS=5
# Limit total search queries sent to Serper. Useful for testing — e.g. set to 10
# to only search 10 queries instead of all 500+ from taxonomy. Empty = use all.
# MAX_QUERIES=10

# ── SFT Annotation ───────────────────────────────────────────────────
# Language for ALL generated training examples (questions + answers).
# REQUIRED — no default. Examples: English, Russian, Kazakh, Chinese
SFT_TARGET_LANGUAGE=English

# ── Model & Training ─────────────────────────────────────────────────
# Base model from HuggingFace to fine-tune with LoRA.
# This is the model that gets downloaded and trained on your data.
HF_MODEL_ID=Qwen/Qwen2.5-1.5B

# Max gradient update steps per training iteration. More steps = longer
# training = potentially better. 200 is reasonable; 10-20 for quick tests.
# MAX_STEPS=200

# Max training iterations. In agentic mode, the agent can retry with
# adjusted hyperparameters up to this many times.
# MAX_ITERS=1

# Limit dataset to first N samples. Leave empty to use all data.
# MAX_SAMPLES=

# Training batch size (per device). Default: 4
# TRAIN_BATCH_SIZE=4

# Max sequence length in tokens. Longer = more context but more memory. Default: 512
# TRAIN_MAX_SEQ_LEN=512

# Random hyperparameter search trials before the main training. 0 = skip.
# SEARCH_TRIALS=0

# ── Evaluation ────────────────────────────────────────────────────────
# How many samples to evaluate on after training. Default: 64
# EVAL_MAX_SAMPLES=64

# ── Hugging Face Hub ─────────────────────────────────────────────────
# API token from https://huggingface.co/settings/tokens (needs write access).
# Used for downloading models and optionally pushing datasets/adapters.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Repo names for auto-pushing after SFT build and after training.
# Leave empty to skip. Repos are created as private under your HF account.
# HF_DATASET_REPO=
# HF_ADAPTER_REPO=
